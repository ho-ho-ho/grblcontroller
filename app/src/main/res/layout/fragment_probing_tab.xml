<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <variable name="machineStatus" type="in.co.gorest.grblcontroller.listeners.MachineStatusListener" />
    </data>

    <ScrollView
        android:paddingTop="4dp"
        android:fillViewport="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RelativeLayout
                android:id="@+id/probing_help"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                android:minHeight="48dp"
                android:padding="4dp"
                tools:targetApi="m"
                tools:ignore="UnusedAttribute">

                <com.joanzapata.iconify.widget.IconTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="@string/text_probing_tab_heading"
                    tools:ignore="RelativeOverlap" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="G38.3 | G43.1"
                    tools:ignore="HardcodedText" />

            </RelativeLayout>

            <View android:layout_margin="4dp" android:layout_height="0.2dp" android:background="@color/colorDivider" android:layout_width="fill_parent"/>

            <RelativeLayout
                android:id="@+id/probing_x_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:minHeight="48dp"
                android:padding="4dp"
                tools:ignore="UnusedAttribute"
                tools:targetApi="m">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/probe_x_location"
                    android:text="@string/text_probing_x_location" />

                <RadioGroup android:id="@+id/probe_x_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_alignParentEnd="true">

                    <RadioButton
                        android:id="@+id/probe_x_left"
                        android:text="@string/text_probing_x_location_left"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <RadioButton
                        android:id="@+id/probe_x_none"
                        android:text="@string/text_probing_x_location_none"
                        android:checked="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <RadioButton
                        android:id="@+id/probe_x_right"
                        android:text="@string/text_probing_x_location_right"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </RadioGroup>

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/probing_y_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:minHeight="48dp"
                android:padding="4dp"
                tools:ignore="UnusedAttribute"
                tools:targetApi="m">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/probe_y_location"
                    android:text="@string/text_probing_y_location" />

                <RadioGroup android:id="@+id/probe_y_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentEnd="true">

                    <RadioButton
                        android:id="@+id/probe_y_back"
                        android:text="@string/text_probing_y_location_back"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <RadioButton
                        android:id="@+id/probe_y_none"
                        android:text="@string/text_probing_y_location_none"
                        android:checked="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <RadioButton
                        android:id="@+id/probe_y_front"
                        android:text="@string/text_probing_y_location_front"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </RadioGroup>

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/probe_z_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:minHeight="48dp"
                android:padding="4dp"
                tools:ignore="UnusedAttribute"
                tools:targetApi="m">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/probe_z"
                    android:text="@string/text_probing_probe_z" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/probe_z"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:checked="false"
                    tools:ignore="TouchTargetSizeCheck" />
            </RelativeLayout>

            <RelativeLayout
                android:padding="4dp"
                android:layout_marginBottom="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/auto_zero_after_probe"
                    android:text="@string/text_auto_zero_z_axis_after_probe" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/auto_zero_after_probe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    tools:ignore="TouchTargetSizeCheck" />

            </RelativeLayout>

            <View android:layout_margin="4dp" android:layout_height="0.2dp" android:background="@color/colorDivider" android:layout_width="fill_parent"/>

            <RelativeLayout
                android:padding="4dp"
                android:layout_marginBottom="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.joanzapata.iconify.widget.IconButton
                    android:id="@+id/start_probe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="@{machineStatus.state.equals(machineStatus.STATE_IDLE)}"
                    android:text="@string/text_start_probe" />

            </RelativeLayout>

            <View android:layout_margin="4dp" android:layout_height="2dp" android:background="@color/colorDivider" android:layout_width="fill_parent"/>

            <RelativeLayout
                android:padding="4dp"
                android:layout_marginBottom="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/text_dynamic_tool_length_offset" />

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/last_probe_position_view"
                android:padding="4dp"
                android:layout_marginBottom="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_toStartOf="@+id/last_probe_position"
                    android:text="@string/text_last_probe_position"
                    android:layout_alignParentStart="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text='@{(machineStatus.lastProbePosition != null) ? machineStatus.lastProbePosition.cordZ.toString() : @string/text_unknown}'
                    android:id="@+id/last_probe_position"
                    android:layout_alignParentEnd="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </RelativeLayout>

            <RelativeLayout
                android:padding="4dp"
                android:layout_marginBottom="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_toStartOf="@+id/current_tlo"
                    android:text="@string/text_current_tlo"
                    android:layout_alignParentStart="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text='@{machineStatus.toolLengthOffset.toString()}'
                    android:id="@+id/current_tlo"
                    android:layout_alignParentEnd="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </RelativeLayout>

            <TableLayout
                android:layout_centerHorizontal="true"
                android:stretchColumns="*"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:ignore="ObsoleteLayoutParam">

                <TableRow
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" >

                    <com.joanzapata.iconify.widget.IconButton
                        android:id="@+id/cancel_tool_offset"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.33"
                        android:enabled="@{machineStatus.state.equals(machineStatus.STATE_IDLE)}"
                        android:text="TLO {fa-times 16dp}"
                        tools:ignore="HardcodedText" />

                    <com.joanzapata.iconify.widget.IconButton
                        android:id="@+id/start_tool_length_offset"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.33"
                        android:enabled="@{machineStatus.state.equals(machineStatus.STATE_IDLE) &amp;&amp; (machineStatus.lastProbePosition != null)}"
                        android:text="@string/probe_plus_tlo" />
                </TableRow>

            </TableLayout>

        </LinearLayout>

    </ScrollView>

</layout>
